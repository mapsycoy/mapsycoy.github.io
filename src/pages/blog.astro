---
import BlogIndex from "../components/BlogIndex.astro";
import Layout from "../layouts/Layout.astro";
import { getBlogPagePosts, getBlogPosts } from "../data/blog";
import { defaultLanguage } from "../utils/i18n";

const lang = defaultLanguage;
const allPosts = await getBlogPosts();
const posts = getBlogPagePosts(allPosts, 1);
---

<Layout title="Blog" description="Essays, technical notes, and archived writings by mapsycoy." lang={lang}>
  <BlogIndex posts={posts} allPosts={allPosts} lang={lang} currentPage={1} basePath="/blog" />
</Layout>