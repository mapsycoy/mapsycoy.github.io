---
import Layout from "../layouts/Layout.astro";
import { artsGiftedEducationCertificate, education, experiences, profile, projects, publications, type MediaItem } from "../data/cv";
import { defaultLanguage, localize, type Language } from "../utils/i18n";

const lang: Language = defaultLanguage;
const projectInitialCount = 4;

const mediaItems = (items: MediaItem[] | undefined) => items?.filter((item) => item.src || item.href) ?? [];
const thumbnailMediaItems = (items: MediaItem[] | undefined) => mediaItems(items).filter((item) => item.src);
const localizedDescriptionLine = (line: any) => localize(line?.line ?? line, lang);
const certificateItems = artsGiftedEducationCertificate.items ?? artsGiftedEducationCertificate.logos.map((logo) => ({
  institution: logo.alt,
  period: undefined,
  logo: logo.src,
  alt: logo.alt,
}));
const publicationEmptyText = {
  ko: "Manuscripts in preparation.",
  en: "Manuscripts in preparation.",
};
const publicationVenueLine = (item: any) => {
  const venue = localize(item.venue, lang);
  const year = item.year ?? "";
  if (!venue) return year;
  if (!year || venue.includes(year)) return venue;
  return `${venue} ${year}`;
};
---

<Layout title="CV" description="Kim Junyeop's curriculum vitae, including education, experience, and selected projects." lang={lang}>
  <div class="cv-page">
    <section class="cv-profile-main" aria-label="Profile summary">
      <div class="cv-profile-identity">
        <div class="cv-profile-photo" aria-hidden={!profile.photo}>
          {profile.photo && <img src={profile.photo} alt="" loading="lazy" onerror="this.hidden=true" />}
        </div>
      </div>
      <div class="cv-profile-education" aria-label="Education">
        <div class="cv-profile-heading">
          <div class="cv-profile-name-row">
            <p class="cv-profile-name">{localize(profile.name, lang)}</p>
            {profile.location && <p class="cv-profile-location">{localize(profile.location, lang)}</p>}
          </div>
          <p class="cv-profile-headline">{localize(profile.headline, lang)}</p>
        </div>
        {education.map((item) => (
          <article class="cv-profile-education-item">
            <h2 class="cv-profile-education-title">
              <span>{localize(item.degree, lang)}</span>
              <span>{localize(item.institution, lang)}</span>
            </h2>
            <p class="cv-entry-period">{localize(item.period, lang)}</p>
            {item.description && (
              <ul class="cv-entry-description">
                {item.description.map((line) => <li>{localizedDescriptionLine(line)}</li>)}
              </ul>
            )}
          </article>
        ))}
        <article class="cv-profile-education-item cv-certificate">
          <h2 class="cv-profile-education-title">
            <span>{localize(artsGiftedEducationCertificate.title, lang)}</span>
          </h2>
          <div class="cv-certificate-list" aria-label={`${localize(artsGiftedEducationCertificate.title, lang)} certificates`}>
            {certificateItems.map((item, index) => (
              <div class="cv-certificate-entry">
                <div class="cv-certificate-logo" aria-hidden="true">
                  {item.logo ? (
                    <img src={item.logo} alt="" loading="lazy" onerror="this.hidden=true" />
                  ) : (
                    <span>Logo {index + 1}</span>
                  )}
                </div>
                <p class="cv-certificate-meta">
                  <span>{localize(item.institution, lang) || localize(item.alt, lang)}</span>
                  {item.period && localize(item.period, lang) && <span>{localize(item.period, lang)}</span>}
                </p>
              </div>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="cv-section-block" aria-labelledby="experience-heading">
      <h2 class="cv-section-header" id="experience-heading">Experience</h2>
      <div class="cv-list">
        {experiences.map((item) => (
          <article class="cv-entry">
            <div class="cv-entry-logo" aria-hidden="true">
              {item.logo && <img src={item.logo} alt="" loading="lazy" onerror="this.hidden=true" />}
            </div>
            <div class="cv-entry-main">
              <h3 class="cv-entry-title">
                {localize(item.role, lang)}
                {item.team && <span class="cv-entry-team">{localize(item.team, lang)}</span>}
              </h3>
              <p class="cv-entry-meta">
                {localize(item.organization, lang)}{item.employmentType && ` / ${localize(item.employmentType, lang)}`}
              </p>
              <p class="cv-entry-period">
                {localize(item.period, lang)}{item.duration && ` / ${localize(item.duration, lang)}`}
              </p>
              {item.description && (
                <ul class="cv-entry-description">
                  {item.description.map((line) => <li>{localizedDescriptionLine(line)}</li>)}
                </ul>
              )}

              {item.subEntries && (
                <div class="cv-subentries">
                  {item.subEntries.map((subEntry) => (
                    <div class="cv-subentry">
                      <h4>{localize(subEntry.title, lang)}</h4>
                      <p class="cv-entry-period">
                        {localize(subEntry.period, lang)}{subEntry.duration && ` / ${localize(subEntry.duration, lang)}`}
                      </p>
                      {subEntry.description && (
                        <ul class="cv-entry-description">
                          {subEntry.description.map((line) => <li>{localizedDescriptionLine(line)}</li>)}
                        </ul>
                      )}
                    </div>
                  ))}
                </div>
              )}

              {mediaItems(item.media).length > 0 && (
                <div class="cv-media-row">
                  {mediaItems(item.media).map((media) => (
                    media.href ? (
                      <a class="cv-media-thumb" href={media.href} aria-label={localize(media.label, lang) || localize(media.alt, lang) || "Open related media"}>
                        {media.src ? (
                          <img src={media.src} alt={localize(media.alt, lang)} loading="lazy" onerror="this.hidden=true" />
                        ) : (
                          <span>{localize(media.label, lang) || "Open link"}</span>
                        )}
                      </a>
                    ) : (
                      <div class="cv-media-thumb">
                        <img src={media.src} alt={localize(media.alt, lang)} loading="lazy" onerror="this.hidden=true" />
                      </div>
                    )
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>

    </section>

    <section class="cv-section-block cv-section-block-no-rule" aria-labelledby="projects-heading" data-cv-section>
      <h2 class="cv-section-header" id="projects-heading">Projects</h2>
      <div class="cv-list">
        {projects.map((item, index) => (
          <article class="cv-entry cv-project-entry" data-cv-item hidden={index >= projectInitialCount}>
            <div class="cv-entry-main">
              <div class="cv-project-heading">
                <h3 class="cv-entry-title">{localize(item.title, lang)}</h3>
                <p class="cv-entry-period">{localize(item.period, lang)}</p>
              </div>
              {item.description && (
                <ul class="cv-entry-description">
                  {item.description.map((line) => <li>{localizedDescriptionLine(line)}</li>)}
                </ul>
              )}
              {thumbnailMediaItems(item.media).length > 0 && (
                <div class="cv-media-row">
                  {thumbnailMediaItems(item.media).map((media) => (
                    media.href ? (
                      <a
                        class="cv-media-thumb"
                        href={media.href}
                        aria-label={localize(media.label, lang) || localize(media.alt, lang) || "Open project media"}
                        target={media.href.startsWith("http") ? "_blank" : undefined}
                        rel={media.href.startsWith("http") ? "noreferrer" : undefined}
                      >
                        <img src={media.src} alt={localize(media.alt, lang)} loading="lazy" onerror="this.hidden=true" />
                      </a>
                    ) : (
                      <div class="cv-media-thumb">
                        <img src={media.src} alt={localize(media.alt, lang)} loading="lazy" onerror="this.hidden=true" />
                      </div>
                    )
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
      {projects.length > projectInitialCount && (
        <button
          class="cv-show-toggle"
          type="button"
          data-cv-toggle
          data-initial-count={projectInitialCount}
          data-total-count={projects.length}
          data-label="projects"
          aria-expanded="false"
        >
          Show all {projects.length} projects
        </button>
      )}
    </section>

    <section class="cv-section-block cv-section-block-no-rule" aria-labelledby="publications-heading">
      <h2 class="cv-section-header" id="publications-heading">Publications</h2>
      {publications.length > 0 ? (
        <div class="cv-list">
          {publications.map((item) => (
            <article class="cv-entry cv-publication-entry">
              <div class="cv-entry-main">
                <h3 class="cv-entry-title">{localize(item.title, lang)}</h3>
                <p class="cv-publication-authors">{item.authors.map((author) => localize(author, lang)).join(", ")}</p>
                {(publicationVenueLine(item) || item.status || (item.links && item.links.length > 0)) && (
                  <p class="cv-publication-meta-line">
                    {publicationVenueLine(item) && <span class="cv-publication-venue">{publicationVenueLine(item)}</span>}
                    {item.status && <span class="cv-publication-status">{localize(item.status, lang)}</span>}
                    {item.links?.map((link) => (
                      <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                        {localize(link.label, lang)}
                      </a>
                    ))}
                  </p>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="cv-empty-note">{localize(publicationEmptyText, lang)}</p>
      )}
    </section>
  </div>

</Layout>
