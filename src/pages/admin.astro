---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>mapsycoy Admin</title>
  </head>
  <body>
    <script src="https://unpkg.com/decap-cms@^3.8.0/dist/decap-cms.js"></script>
    <script>
      if (window.CMS) {
        window.CMS.registerEditorComponent({
          id: "divider",
          label: "Divider",
          fields: [],
          pattern: /^---$/m,
          fromBlock: () => ({}),
          toBlock: () => "\n\n---\n\n",
          toPreview: () => "<hr />",
        });

        window.CMS.registerEditorComponent({
          id: "captioned-image",
          label: "Image",
          fields: [
            {
              name: "image",
              label: "Image",
              widget: "image",
            },
            {
              name: "caption",
              label: "Caption",
              widget: "string",
              required: false,
            },
          ],
          pattern: /^!\[([^\]]*)\]\(([^)\s]+)(?:\s+["']([^"']+)["'])?\)$/m,
          fromBlock: (match) => ({
            caption: match[3] || match[1] || "",
            image: match[2],
          }),
          toBlock: ({ image, caption }) => `![${caption || ""}](${image})`,
          toPreview: ({ image, caption }) =>
            `<figure><img src="${image}" alt="" /><figcaption>${caption || ""}</figcaption></figure>`,
        });

        window.CMS.registerEditorComponent({
          id: "image-grid",
          label: "Image Grid",
          fields: [
            {
              name: "columns",
              label: "Columns",
              widget: "select",
              default: "2",
              options: [
                { label: "2 columns", value: "2" },
                { label: "3 columns", value: "3" },
              ],
            },
            {
              name: "images",
              label: "Images",
              widget: "list",
              fields: [
                {
                  name: "image",
                  label: "Image",
                  widget: "image",
                },
                {
                  name: "caption",
                  label: "Caption",
                  widget: "string",
                  required: false,
                },
              ],
            },
          ],
          pattern: /^\{\{image-grid columns="([23])"\}\}\n([\s\S]+?)\n\{\{\/image-grid\}\}$/m,
          fromBlock: (match) => ({
            columns: match[1],
            images: match[2]
              .split(/\n+/)
              .map((line) => line.trim().match(/^!\[([^\]]*)\]\(([^)\s]+)(?:\s+["']([^"']+)["'])?\)$/))
              .filter(Boolean)
              .map((image) => ({
                caption: image[3] || image[1] || "",
                image: image[2],
              })),
          }),
          toBlock: ({ columns, images }) => [
            `{{image-grid columns="${columns || "2"}"}}`,
            ...(images || []).map(({ image, caption }) => `![${caption || ""}](${image})`),
            "{{/image-grid}}",
          ].join("\n"),
          toPreview: ({ columns, images }) =>
            `<div style="display:grid;grid-template-columns:repeat(${columns || "2"},minmax(0,1fr));gap:12px;">${(images || [])
              .map(({ image, caption }) => `<figure><img src="${image}" alt="" /><figcaption>${caption || ""}</figcaption></figure>`)
              .join("")}</div>`,
        });

        const splitTableLine = (line) => {
          const trimmed = `${line || ""}`.trim().replace(/^\|/, "").replace(/\|$/, "");
          return trimmed.split("|").map((cell) => cell.trim());
        };

        const escapeTableCell = (cell) => `${cell || ""}`.replace(/\|/g, "\\|").trim();

        const escapeHtml = (value) =>
          `${value || ""}`
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");

        const normalizeTableRows = (rows) =>
          `${rows || ""}`
            .split(/\r?\n/)
            .map((line) => splitTableLine(line))
            .filter((cells) => cells.some(Boolean));

        const renderMarkdownTable = ({ headers, rows }) => {
          const headerCells = splitTableLine(headers || "Column 1 | Column 2").filter(Boolean);
          const safeHeaders = headerCells.length ? headerCells : ["Column 1", "Column 2"];
          const rowCells = normalizeTableRows(rows);
          const width = safeHeaders.length;
          const normalizeWidth = (cells) => [
            ...cells.slice(0, width),
            ...Array.from({ length: Math.max(0, width - cells.length) }, () => ""),
          ];

          return [
            `| ${safeHeaders.map(escapeTableCell).join(" | ")} |`,
            `| ${safeHeaders.map(() => "---").join(" | ")} |`,
            ...rowCells.map((cells) => `| ${normalizeWidth(cells).map(escapeTableCell).join(" | ")} |`),
          ].join("\n");
        };

        window.CMS.registerEditorComponent({
          id: "table",
          label: "Table",
          fields: [
            {
              name: "headers",
              label: "Headers",
              widget: "string",
              default: "Column 1 | Column 2",
              hint: "Separate columns with a vertical bar: Name | Value | Note",
            },
            {
              name: "rows",
              label: "Rows",
              widget: "text",
              default: "Row 1 | Value 1\nRow 2 | Value 2",
              hint: "Use one row per line. Separate cells with a vertical bar.",
            },
          ],
          pattern: /^\|(.+)\|\n\|([\s:|-]+)\|\n((?:\|.*\|\n?)*)/m,
          fromBlock: (match) => ({
            headers: splitTableLine(match[1]).join(" | "),
            rows: `${match[3] || ""}`
              .trim()
              .split(/\r?\n/)
              .filter(Boolean)
              .map((line) => splitTableLine(line).join(" | "))
              .join("\n"),
          }),
          toBlock: renderMarkdownTable,
          toPreview: ({ headers, rows }) => {
            const headerCells = splitTableLine(headers || "Column 1 | Column 2").filter(Boolean);
            const safeHeaders = headerCells.length ? headerCells : ["Column 1", "Column 2"];
            const rowCells = normalizeTableRows(rows);

            return `<table><thead><tr>${safeHeaders
              .map((cell) => `<th>${escapeHtml(cell)}</th>`)
              .join("")}</tr></thead><tbody>${rowCells
              .map((cells) => `<tr>${safeHeaders.map((_, index) => `<td>${escapeHtml(cells[index])}</td>`).join("")}</tr>`)
              .join("")}</tbody></table>`;
          },
        });

      }

      const removeOptionalLabels = () => {
        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
        const textNodes = [];

        while (walker.nextNode()) {
          const node = walker.currentNode;
          const text = node.textContent?.trim().toLowerCase();

          if (text === "optional" || text === "(optional)") {
            textNodes.push(node);
          }
        }

        textNodes.forEach((node) => {
          node.textContent = "";
        });
      };

      const observer = new MutationObserver(removeOptionalLabels);

      window.addEventListener("load", () => {
        removeOptionalLabels();
        observer.observe(document.body, { childList: true, subtree: true, characterData: true });
      });

      const destructiveButtonText = /^(delete|delete entry|delete media|delete asset)$/i;
      const destructiveLabelText = /\b(delete|delete entry|delete media|delete asset)\b/i;
      const mediaFileNameText = /\.(avif|gif|jpe?g|png|svg|webp|mp4|mov|webm|pdf|zip|json|csv|txt)\b/i;
      const selectedMediaAssets = new WeakSet();
      const enhancedMediaAssets = new WeakSet();
      const mediaBulkState = {
        selectedCount: 0,
        toolbar: null,
        countNode: null,
        deleteButton: null,
        controls: new Map(),
      };

      const getButtonLabel = (button) =>
        [
          button?.getAttribute("aria-label"),
          button?.getAttribute("title"),
          button?.textContent,
        ]
          .filter(Boolean)
          .join(" ")
          .replace(/\s+/g, " ")
          .trim();

      const isLikelyMediaLibrary = () => {
        const route = `${window.location.hash || ""} ${window.location.pathname || ""}`.toLowerCase();
        const text = document.body?.textContent?.toLowerCase() || "";

        return (
          route.includes("media") ||
          text.includes("media library") ||
          text.includes("media folder") ||
          text.includes("assets")
        );
      };

      const hasMediaPreview = (element) =>
        Boolean(element?.querySelector?.("img, picture, video, canvas, [role='img']")) ||
        mediaFileNameText.test(element?.textContent || "");

      const getMediaAssetRoot = (element) => {
        let node = element;

        for (let depth = 0; node && node !== document.body && depth < 10; depth += 1) {
          const previewCount = node.querySelectorAll?.("img, picture, video, canvas, [role='img']").length || 0;
          const buttonCount = node.querySelectorAll?.("button, [role='button']").length || 0;

          if (hasMediaPreview(node) && previewCount <= 3 && buttonCount <= 8) {
            return node;
          }

          node = node.parentElement;
        }

        return null;
      };

      const getMediaAssetEntries = () => {
        if (!isLikelyMediaLibrary()) return [];

        const roots = new Set();
        const previewElements = Array.from(document.querySelectorAll("img, picture, video, canvas, [role='img']"));
        const fileNameElements = Array.from(document.querySelectorAll("a, button, span, p, div")).filter((element) =>
          mediaFileNameText.test(element.textContent || "")
        );

        [...previewElements, ...fileNameElements].forEach((element) => {
          const root = getMediaAssetRoot(element);
          if (!root || root.closest(".mapsycoy-media-bulk-toolbar")) return;

          const text = root.textContent || "";
          const image = root.querySelector?.("img");
          const src = image?.getAttribute("src") || "";

          if (mediaFileNameText.test(text) || src.includes("/uploads/") || src.includes("/media/")) {
            roots.add(root);
          }
        });

        const dedupedRoots = Array.from(roots).filter(
          (root, _, allRoots) => !allRoots.some((otherRoot) => otherRoot !== root && root.contains(otherRoot))
        );

        return dedupedRoots.map((root) => ({ root }));
      };

      const findVisibleMediaDeleteButton = () =>
        Array.from(document.querySelectorAll("button, [role='button']")).find((button) => {
          const label = getButtonLabel(button);
          const isDelete =
            /\bdelete\s+(media|asset|file)\b/i.test(label) ||
            (/^delete$/i.test(label) && !/\bentry\b/i.test(label));

          if (!isDelete || button.dataset.deleteConfirmed === "true") return false;

          const rect = button.getBoundingClientRect?.();
          return !rect || (rect.width > 0 && rect.height > 0);
        });

      const waitForMediaDeleteButton = async () => {
        for (let attempt = 0; attempt < 12; attempt += 1) {
          const button = findVisibleMediaDeleteButton();
          if (button) return button;

          await new Promise((resolve) => window.setTimeout(resolve, 150));
        }

        return null;
      };

      const openMediaAsset = async (root) => {
        const actionTarget = Array.from(root.querySelectorAll?.("button, a, [role='button']") || []).find(
          (item) => !item.closest(".mapsycoy-media-select-control")
        );
        const target =
          root.querySelector?.("img, picture, video, canvas, [role='img']") ||
          actionTarget ||
          root;

        target.dispatchEvent(new MouseEvent("click", { bubbles: true, cancelable: true, view: window }));
        await new Promise((resolve) => window.setTimeout(resolve, 250));
      };

      const getSelectedMediaAssetEntries = () =>
        getMediaAssetEntries().filter(({ root }) => selectedMediaAssets.has(root));

      const clickCloseMediaPreview = () => {
        const closeButton = Array.from(document.querySelectorAll("button, [role='button']")).find((button) => {
          const label = getButtonLabel(button);
          return /^(close|back|cancel)$/i.test(label);
        });

        if (closeButton) {
          closeButton.click();
        } else {
          document.dispatchEvent(new KeyboardEvent("keydown", { key: "Escape", bubbles: true }));
        }
      };

      const runBulkMediaDelete = async (entries) => {
        for (const { root } of entries) {
          await openMediaAsset(root);

          const button = await waitForMediaDeleteButton();
          if (!button) {
            clickCloseMediaPreview();
            await new Promise((resolve) => window.setTimeout(resolve, 250));
            continue;
          }

          button.dataset.deleteConfirmed = "true";
          button.click();
          await new Promise((resolve) => window.setTimeout(resolve, 650));
        }
      };

      const syncMediaBulkToolbar = () => {
        if (!mediaBulkState.countNode || !mediaBulkState.deleteButton) return;

        mediaBulkState.countNode.textContent = `${mediaBulkState.selectedCount} selected`;
        mediaBulkState.deleteButton.disabled = mediaBulkState.selectedCount === 0;
      };

      const ensureMediaBulkToolbar = () => {
        if (mediaBulkState.toolbar) return mediaBulkState.toolbar;

        const toolbar = document.createElement("div");
        toolbar.className = "mapsycoy-media-bulk-toolbar";
        toolbar.innerHTML = [
          '<span class="mapsycoy-media-bulk-count">0 selected</span>',
          '<button class="mapsycoy-media-bulk-delete" type="button" disabled>Delete selected</button>',
          '<button class="mapsycoy-media-bulk-clear" type="button">Clear</button>',
        ].join("");

        const countNode = toolbar.querySelector(".mapsycoy-media-bulk-count");
        const deleteButton = toolbar.querySelector(".mapsycoy-media-bulk-delete");
        const clearButton = toolbar.querySelector(".mapsycoy-media-bulk-clear");

        clearButton.addEventListener("click", () => {
          Array.from(document.querySelectorAll(".mapsycoy-media-select-input")).forEach((input) => {
            input.checked = false;
            input.dispatchEvent(new Event("change", { bubbles: true }));
          });
        });

        deleteButton.addEventListener("click", async () => {
          const entries = getSelectedMediaAssetEntries();

          if (entries.length === 0) return;

          const confirmation = window.prompt(
            `This will delete ${entries.length} selected media file${entries.length === 1 ? "" : "s"} from the repository.\n\nType DELETE to confirm.`
          );

          if (confirmation !== "DELETE") return;

          await runBulkMediaDelete(entries);
        });

        mediaBulkState.toolbar = toolbar;
        mediaBulkState.countNode = countNode;
        mediaBulkState.deleteButton = deleteButton;
        document.body.appendChild(toolbar);
        syncMediaBulkToolbar();

        return toolbar;
      };

      const removeMediaSelectControl = (root) => {
        const control = mediaBulkState.controls.get(root);
        if (control) {
          control.remove();
          mediaBulkState.controls.delete(root);
        }

        enhancedMediaAssets.delete(root);

        if (selectedMediaAssets.has(root)) {
          selectedMediaAssets.delete(root);
          mediaBulkState.selectedCount = Math.max(0, mediaBulkState.selectedCount - 1);
        }
      };

      const updateMediaSelection = (root, isSelected) => {
        if (isSelected) {
          if (!selectedMediaAssets.has(root)) {
            selectedMediaAssets.add(root);
            mediaBulkState.selectedCount += 1;
          }
        } else if (selectedMediaAssets.has(root)) {
          selectedMediaAssets.delete(root);
          mediaBulkState.selectedCount = Math.max(0, mediaBulkState.selectedCount - 1);
        }

        root.classList.toggle("mapsycoy-media-selected", isSelected);
        syncMediaBulkToolbar();
      };

      const enhanceMediaBulkSelection = () => {
        const entries = getMediaAssetEntries();
        const activeRoots = new Set(entries.map(({ root }) => root));

        mediaBulkState.controls.forEach((control, root) => {
          if (!activeRoots.has(root) || !document.body.contains(root)) {
            removeMediaSelectControl(root);
          }
        });

        if (entries.length === 0) {
          if (mediaBulkState.toolbar) {
            mediaBulkState.toolbar.hidden = true;
          }
          return;
        }

        ensureMediaBulkToolbar().hidden = false;

        entries.forEach(({ root }) => {
          if (mediaBulkState.controls.has(root)) return;

          enhancedMediaAssets.add(root);
          root.classList.add("mapsycoy-media-selectable");

          const control = document.createElement("label");
          control.className = "mapsycoy-media-select-control";
          control.innerHTML = '<input class="mapsycoy-media-select-input" type="checkbox" aria-label="Select media file" /><span>Select</span>';

          const input = control.querySelector("input");
          input.addEventListener("click", (event) => {
            event.stopPropagation();
          });
          input.addEventListener("change", () => {
            updateMediaSelection(root, input.checked);
          });

          root.appendChild(control);
          mediaBulkState.controls.set(root, control);
        });

        syncMediaBulkToolbar();
      };

      const injectAdminStyles = () => {
        if (document.getElementById("mapsycoy-admin-enhancements")) return;

        const style = document.createElement("style");
        style.id = "mapsycoy-admin-enhancements";
        style.textContent = `
          .mapsycoy-media-bulk-toolbar {
            position: fixed;
            right: 18px;
            bottom: 18px;
            z-index: 2147483647;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border: 1px solid rgba(23, 23, 23, 0.2);
            border-radius: 4px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
            color: #171717;
            font: 13px/1.3 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
          }

          .mapsycoy-media-bulk-toolbar[hidden] {
            display: none;
          }

          .mapsycoy-media-bulk-toolbar button {
            min-height: 30px;
            padding: 0 10px;
            border: 1px solid rgba(23, 23, 23, 0.28);
            border-radius: 3px;
            background: #f8f8f5;
            color: #171717;
            cursor: pointer;
          }

          .mapsycoy-media-bulk-toolbar button:disabled {
            cursor: not-allowed;
            opacity: 0.45;
          }

          .mapsycoy-media-bulk-delete:not(:disabled) {
            border-color: #8b1e1e;
            color: #8b1e1e;
          }

          .mapsycoy-media-selectable {
            position: relative !important;
          }

          .mapsycoy-media-selected {
            outline: 2px solid #2f4f48 !important;
            outline-offset: 2px !important;
          }

          .mapsycoy-media-select-control {
            position: absolute;
            top: 8px;
            left: 8px;
            z-index: 20;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            box-sizing: border-box;
            padding: 5px 7px;
            border: 1px solid rgba(23, 23, 23, 0.2);
            border-radius: 3px;
            background: rgba(255, 255, 255, 0.94);
            color: #171717;
            font: 12px/1.2 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            white-space: nowrap;
            cursor: pointer;
            pointer-events: auto;
          }

          .mapsycoy-media-select-input {
            margin: 0;
          }
        `;

        document.head.appendChild(style);
      };

      document.addEventListener(
        "click",
        (event) => {
          const button = event.target?.closest?.("button, [role='button']");

          if (!button) return;

          const label = getButtonLabel(button);
          const isDeleteAction =
            destructiveButtonText.test(label) ||
            (destructiveLabelText.test(label) && !/\bremove\b/i.test(label));

          if (!isDeleteAction || button.dataset.deleteConfirmed === "true") return;

          const confirmation = window.prompt(
            "This will permanently delete the entry or media file from the repository.\n\nType DELETE to confirm."
          );

          if (confirmation !== "DELETE") {
            event.preventDefault();
            event.stopPropagation();
            event.stopImmediatePropagation();
            return;
          }

          button.dataset.deleteConfirmed = "true";
          window.setTimeout(() => {
            delete button.dataset.deleteConfirmed;
          }, 0);
        },
        true
      );

      const mediaBulkObserver = new MutationObserver(() => {
        window.requestAnimationFrame(enhanceMediaBulkSelection);
      });

      window.addEventListener("load", () => {
        injectAdminStyles();
        enhanceMediaBulkSelection();
        mediaBulkObserver.observe(document.body, { childList: true, subtree: true });
      });
    </script>
  </body>
</html>
