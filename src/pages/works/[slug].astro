---
import Layout from "../../layouts/Layout.astro";
import { getWorks, type WorkItem } from "../../data/works";
import { getLinkPreviewImage } from "../../utils/linkMetadata";
import { defaultLanguage, localize, type Language } from "../../utils/i18n";

type Props = {
  work: WorkItem;
};

export async function getStaticPaths() {
  const works = await getWorks();

  return works.map((work) => ({
    params: { slug: work.id },
    props: { work }
  }));
}

const getVideoSource = (value: string) => {
  const trimmedValue = value.trim();
  const iframeSource = trimmedValue.match(/<iframe[^>]+src=["']([^"']+)["']/i)?.[1];

  return (iframeSource ?? trimmedValue).replaceAll("&amp;", "&");
};

const withVimeoEmbedParams = (url: string) => {
  const parsed = new URL(url);

  parsed.searchParams.set("transparent", "0");
  parsed.searchParams.set("title", "0");
  parsed.searchParams.set("byline", "0");
  parsed.searchParams.set("portrait", "0");
  parsed.searchParams.set("badge", "0");
  parsed.searchParams.set("dnt", "1");

  return parsed.toString();
};

const getYouTubeEmbedSearch = (parsed: URL) => {
  const searchParams = new URLSearchParams(parsed.search);
  searchParams.delete("v");
  return searchParams.toString() ? `?${searchParams.toString()}` : "";
};

const getVideoEmbedUrl = (value: string): string | null => {
  if (!value.trim()) return null;

  const url = getVideoSource(value);

  try {
    const parsed = new URL(url);
    const host = parsed.hostname.replace(/^www\./, "");

    if (host === "youtube.com" || host === "m.youtube.com" || host === "youtube-nocookie.com") {
      if (parsed.pathname === "/watch") {
        const id = parsed.searchParams.get("v");
        return id ? `https://www.youtube.com/embed/${id}${getYouTubeEmbedSearch(parsed)}` : null;
      }

      if (parsed.pathname.startsWith("/embed/")) {
        return `https://www.youtube.com${parsed.pathname}${parsed.search}`;
      }

      if (parsed.pathname.startsWith("/shorts/")) {
        const id = parsed.pathname.split("/").filter(Boolean)[1];
        return id ? `https://www.youtube.com/embed/${id}${getYouTubeEmbedSearch(parsed)}` : null;
      }

      if (parsed.pathname.startsWith("/live/")) {
        const id = parsed.pathname.split("/").filter(Boolean)[1];
        return id ? `https://www.youtube.com/embed/${id}${getYouTubeEmbedSearch(parsed)}` : null;
      }
    }

    if (host === "youtu.be") {
      const id = parsed.pathname.split("/").filter(Boolean)[0];
      return id ? `https://www.youtube.com/embed/${id}${getYouTubeEmbedSearch(parsed)}` : null;
    }

    if (host === "vimeo.com") {
      const id = parsed.pathname.split("/").filter(Boolean)[0];
      return id ? withVimeoEmbedParams(`https://player.vimeo.com/video/${id}`) : null;
    }

    if (host === "player.vimeo.com" && parsed.pathname.startsWith("/video/")) {
      return withVimeoEmbedParams(`https://player.vimeo.com${parsed.pathname}${parsed.search}`);
    }
  } catch {
    return null;
  }

  return null;
};

const isVideoProviderUrl = (value: string) => {
  try {
    const parsed = new URL(value);
    const host = parsed.hostname.replace(/^www\./, "");
    return ["youtube.com", "m.youtube.com", "youtube-nocookie.com", "youtu.be", "vimeo.com", "player.vimeo.com"].includes(host);
  } catch {
    return false;
  }
};

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");

const escapeAttribute = (value: string) => escapeHtml(value).replaceAll("'", "&#39;");

const renderInlineMarkdown = (value: string) =>
  escapeHtml(value)
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>")
    .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" loading="lazy">')
    .replace(/\[((?:[^\[\]]|\[[^\]]*\])+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noreferrer">$1</a>')
    .replace(/&lt;(https?:\/\/[^&\s]+)&gt;/g, '<a href="$1" target="_blank" rel="noreferrer">$1</a>')
    .replace(
      /\{\{color:(accent|ink|muted|rust|blue)\}\}([\s\S]*?)\{\{\/color\}\}/g,
      '<span class="work-text-color work-text-color-$1">$2</span>'
    );

const renderParagraph = (value: string) => `<p>${renderInlineMarkdown(value).replace(/\n/g, "<br>")}</p>`;

const getMarkdownImage = (value: string) =>
  value.match(/^!\[([^\]]*)\]\(([^)\s]+)(?:\s+["']([^"']+)["'])?\)$/);

const getStandaloneLink = (value: string) =>
  value.match(/^(?:\\?\[([\s\S]+)\]\((https?:\/\/[^)\s]+)\)|<((?:https?:\/\/)[^>\s]+)>|(https?:\/\/\S+))$/);

const getLinkHost = (value: string) => {
  try {
    return new URL(value).hostname.replace(/^www\./, "");
  } catch {
    return value;
  }
};

const normalizeLinkLabel = (value: string) => value.replace(/\\([\[\]])/g, "$1");

const renderLinkPreview = (match: RegExpMatchArray) => {
  const href = match[2] || match[3] || match[4];
  const label = match[1] ? normalizeLinkLabel(match[1]) : getLinkHost(href);

  return [
    `<p class="text-link-preview">`,
    `<a href="${escapeAttribute(href)}" target="_blank" rel="noreferrer">`,
    `<span class="text-link-preview-label">Link</span>`,
    `<span class="text-link-preview-title">${renderInlineMarkdown(label)}</span>`,
    `<span class="text-link-preview-url">${escapeHtml(href)}</span>`,
    "</a>",
    "</p>",
  ].join("");
};

const renderVideoItem = (embedUrl: string, caption = "") =>
  [
    `<div class="work-video-item">`,
    `<div class="work-video-embed">`,
    `<iframe src="${escapeAttribute(embedUrl)}" title="${escapeAttribute(caption || "Embedded video")}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>`,
    "</div>",
    caption ? `<p class="work-video-caption">${renderInlineMarkdown(caption)}</p>` : "",
    "</div>",
  ].join("");

const renderMediaLink = (href: string, label = "") => {
  const title = label || getLinkHost(href);

  return [
    `<p class="text-link-preview">`,
    `<a href="${escapeAttribute(href)}" target="_blank" rel="noreferrer">`,
    `<span class="text-link-preview-label">Link</span>`,
    `<span class="text-link-preview-title">${renderInlineMarkdown(title)}</span>`,
    `<span class="text-link-preview-url">${escapeHtml(href)}</span>`,
    "</a>",
    "</p>",
  ].join("");
};

const getEmbedLabel = (provider: "x" | "reddit") => {
  if (provider === "x") return "X post";
  return "Reddit post";
};

const stripEmbedScripts = (value: string) =>
  value
    .replace(/<script\b[\s\S]*?<\/script>/gi, "")
    .replace(/\s+on[a-z]+\s*=\s*("[^"]*"|'[^']*'|[^\s>]+)/gi, "")
    .trim();

const renderExternalEmbed = ({
  provider,
  embedCode = "",
  url,
  caption = "",
}: {
  provider: "x" | "reddit";
  embedCode?: string;
  url?: string;
  caption?: string;
}) => {
  const html = stripEmbedScripts(embedCode);
  const href = url?.trim() ?? "";
  const label = caption || getEmbedLabel(provider);

  if (html) {
    return [
      `<figure class="work-social-embed work-social-embed-${provider}">`,
      `<div class="work-social-embed-inner">${html}</div>`,
      caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
      `</figure>`,
    ].join("");
  }

  if (!/^https?:\/\//i.test(href)) return "";

  if (provider === "x") {
    return [
      `<figure class="work-social-embed work-social-embed-x">`,
      `<blockquote class="twitter-tweet" data-media-max-width="560">`,
      `<a href="${escapeAttribute(href)}">${escapeHtml(label)}</a>`,
      `</blockquote>`,
      caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
      `</figure>`,
    ].join("");
  }

  if (provider === "reddit") {
    return [
      `<figure class="work-social-embed work-social-embed-reddit">`,
      `<blockquote class="reddit-embed-bq">`,
      `<a href="${escapeAttribute(href)}">${escapeHtml(label)}</a>`,
      `</blockquote>`,
      caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
      `</figure>`,
    ].join("");
  }

  return "";
};

const renderCaptionedImage = (match: RegExpMatchArray) => {
  const caption = match[3] || match[1] || "";
  const embedUrl = getVideoEmbedUrl(match[2]);

  if (embedUrl) {
    return renderVideoItem(embedUrl, caption);
  }

  if (isVideoProviderUrl(match[2])) {
    return renderMediaLink(match[2], caption);
  }

  return [
    "<figure>",
    `<img src="${escapeAttribute(match[2])}" alt="" loading="lazy">`,
    caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
    "</figure>",
  ].join("");
};

const getImageGrid = (value: string) =>
  value.match(/^\{\{image-grid columns="([23])"\}\}\n([\s\S]+)\n\{\{\/image-grid\}\}$/);

const renderImageGrid = (match: RegExpMatchArray) => {
  const columns = match[1];
  const images = match[2]
    .split(/\n+/)
    .map((line) => line.trim().match(/^!\[([^\]]*)\]\(([^)\s]+)(?:\s+["']([^"']+)["'])?\)$/))
    .filter((image): image is RegExpMatchArray => Boolean(image));

  if (images.length === 0) return "";

  return [
    `<div class="work-image-grid work-image-grid-${columns}">`,
    ...images.map((image) => {
      const caption = image[3] || image[1] || "";
      const embedUrl = getVideoEmbedUrl(image[2]);

      if (embedUrl) {
        return [
          "<figure>",
          `<div class="work-video-embed">`,
          `<iframe src="${escapeAttribute(embedUrl)}" title="${escapeAttribute(caption || "Embedded video")}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>`,
          "</div>",
          caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
          "</figure>",
        ].join("");
      }

      if (isVideoProviderUrl(image[2])) {
        return [
          "<figure>",
          `<a href="${escapeAttribute(image[2])}" target="_blank" rel="noreferrer">${escapeHtml(caption || getLinkHost(image[2]))}</a>`,
          caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
          "</figure>",
        ].join("");
      }

      return [
        "<figure>",
        `<img src="${escapeAttribute(image[2])}" alt="" loading="lazy">`,
        caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : "",
        "</figure>",
      ].join("");
    }),
    "</div>",
  ].join("");
};

const renderList = (lines: string[], ordered: boolean) => {
  const tag = ordered ? "ol" : "ul";
  const items = lines
    .map((line) => {
      const markerPattern = ordered ? /^\s*\d+\.\s+/ : /^\s*[-*+]\s+/;
      return `<li>${renderInlineMarkdown(line.replace(markerPattern, "").trim())}</li>`;
    })
    .join("");

  return `<${tag}>${items}</${tag}>`;
};

const renderTextBlock = (value: string) => {
  const blocks = value.trim().split(/\n{2,}/);

  return blocks
    .map((block) => {
      const trimmedBlock = block.trim();
      const lines = trimmedBlock.split(/\n/).map((line) => line.trimEnd());
      const imageGridMatch = getImageGrid(trimmedBlock);
      const imageMatch = getMarkdownImage(trimmedBlock);
      const linkMatch = getStandaloneLink(trimmedBlock);
      const headingMatch = trimmedBlock.match(/^(#{1,6})\s+(.+)$/);
      const isDivider = /^ {0,3}([-*_])(?:\s*\1){2,}\s*$/.test(trimmedBlock);
      const isBlockquote = lines.every((line) => line.trim().startsWith(">"));
      const isOrderedList = lines.every((line) => /^\s*\d+\.\s+/.test(line));
      const isUnorderedList = lines.every((line) => /^\s*[-*+]\s+/.test(line));

      if (imageGridMatch) {
        return renderImageGrid(imageGridMatch);
      }

      if (imageMatch) {
        return renderCaptionedImage(imageMatch);
      }

      if (linkMatch) {
        return renderLinkPreview(linkMatch);
      }

      if (isDivider) {
        return "<hr>";
      }

      if (headingMatch) {
        const level = headingMatch[1].length;
        return `<h${level}>${renderInlineMarkdown(headingMatch[2].trim())}</h${level}>`;
      }

      if (isBlockquote) {
        const quote = lines.map((line) => line.replace(/^\s*>\s?/, "")).join("\n").trim();
        return `<blockquote>${renderParagraph(quote)}</blockquote>`;
      }

      if (isOrderedList || isUnorderedList) {
        return renderList(lines, isOrderedList);
      }

      return renderParagraph(trimmedBlock);
    })
    .join("");
};

const { work, lang = defaultLanguage } = Astro.props;
const workTitle = localize(work.data.title, lang);
const tags = work.data.tags ?? [];
const heroImage = work.data.heroImage?.trim() ?? "";
const heroImageDisplay = work.data.heroImageDisplay ?? "full";
const heroImageCaption = localize(work.data.heroImageCaption, lang).trim();
const videoUrl = work.data.videoUrl?.trim() ?? "";
const legacyVideoItems = [
  ...(work.data.videos ?? []).map((video) => ({
    embedUrl: getVideoEmbedUrl(video.embed),
    caption: localize(video.caption, lang),
  })),
  ...(videoUrl
    ? [
        {
          embedUrl: getVideoEmbedUrl(videoUrl),
          caption: "",
        },
      ]
    : []),
].filter((video): video is { embedUrl: string; caption?: string } => Boolean(video.embedUrl));
const blockItems = await Promise.all((work.data.contentBlocks ?? []).map(async (block) => {
  if (block.type === "video") {
    return {
      ...block,
      embedUrl: getVideoEmbedUrl(block.embed),
    };
  }

  if (block.type === "statsLink") {
    return {
      ...block,
      stats: block.stats.map((stat) => ({ ...stat, label: localize(stat.label, lang) })).filter((stat) => stat.label.trim() && stat.value.trim()),
      previewImage: await getLinkPreviewImage(block.url),
    };
  }

  return block;
}));
const blockVideos = blockItems
  .filter(
    (block): block is { type: "video"; embed: string; embedUrl: string; caption?: string } =>
      block.type === "video" && Boolean(block.embedUrl)
  )
  .map((video) => ({
    ...video,
    caption: localize(video.caption, lang),
  }));
const hasXEmbed = blockItems.some((block) => block.type === "embed" && block.provider === "x");
const hasRedditEmbed = blockItems.some((block) => block.type === "embed" && block.provider === "reddit");
const hasContentBlocks = blockItems.length > 0;
const videoItems = hasContentBlocks ? blockVideos : legacyVideoItems;
const uniqueVideoItems = videoItems.filter(
  (video, index, videos) => videos.findIndex((item) => item.embedUrl === video.embedUrl) === index
);
const leadVideo = !heroImage ? uniqueVideoItems[0] : undefined;
const legacySectionVideos = hasContentBlocks ? [] : legacyVideoItems.filter(
  (video) => video.embedUrl && video.embedUrl !== leadVideo?.embedUrl
);
const infoItems: { label: string; value: string | undefined; icon?: "location" }[] = [
  { label: "Role", value: localize(work.data.artistOrRole, lang) },
  { label: "Year", value: work.data.year },
  { label: "Location", value: localize(work.data.venue, lang), icon: "location" }
];
const visibleInfoItems = infoItems.filter(
  (item): item is { label: string; value: string; icon?: "location" } => Boolean(item.value)
);
---

<Layout title={`${workTitle} | Works`} description={workTitle} lang={lang}>
  <article class="work-detail">
    <a class="work-back-link" href="/works/">&#8592; Works</a>

    <header class="work-detail-header">
      <h1 class="work-detail-title">{workTitle}</h1>
    </header>

    {visibleInfoItems.length > 0 && (
      <dl class="work-info-list" aria-label="Project information">
        {visibleInfoItems.map((item) => (
          <div>
            <dt class:list={[item.icon === "location" && "work-meta-icon-label"]}>
              {item.icon === "location" ? (
                <>
                  <svg class="work-meta-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path
                      fill="currentColor"
                      d="M12 2.75c-3.31 0-6 2.69-6 6 0 4.5 6 12.5 6 12.5s6-8 6-12.5c0-3.31-2.69-6-6-6Zm0 8.25a2.25 2.25 0 1 1 0-4.5 2.25 2.25 0 0 1 0 4.5Z"
                    />
                  </svg>
                  <span class="sr-only">Location</span>
                </>
              ) : (
                item.label
              )}
            </dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    )}

    <section class:list={["work-media-carousel", (leadVideo || heroImage) && "work-media-carousel-unframed"]} data-work-carousel aria-label={`${workTitle} media`}>
      {leadVideo ? (
        <div class="work-video-item">
          <div class="work-video-embed">
            <iframe
              src={leadVideo.embedUrl}
              title={`${workTitle} video`}
              loading="eager"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
          {leadVideo.caption && <p class="work-video-caption">{leadVideo.caption}</p>}
        </div>
      ) : heroImage ? (
        <figure class:list={["work-media-slide", heroImageDisplay === "contained" && "work-media-slide-contained"]}>
          <img src={heroImage} alt={`${workTitle} image`} loading="eager" />
          {heroImageCaption && <figcaption>{heroImageCaption}</figcaption>}
        </figure>
      ) : (
        <div class="work-detail-placeholder" aria-hidden="true"></div>
      )}
    </section>

    <section class="work-section work-description-section work-section-full">
      <div class="work-detail-body work-content-flow">
        {legacySectionVideos.map((video, index) => (
          <div class="work-video-item">
            <div class="work-video-embed">
              <iframe
                src={video.embedUrl}
                title={`${workTitle} video ${index + 1}`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
            {video.caption && <p class="work-video-caption">{video.caption}</p>}
          </div>
        ))}
        {blockItems.map((block, index) => (
          block.type === "text" ? (
            <div class="work-text-block" set:html={renderTextBlock(localize(block.body, lang))} />
          ) : block.type === "video" && block.embedUrl && block.embedUrl !== leadVideo?.embedUrl ? (
            <div class="work-video-item">
              <div class="work-video-embed">
                <iframe
                  src={block.embedUrl}
                  title={`${workTitle} video block ${index + 1}`}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
              {localize(block.caption, lang) && <p class="work-video-caption">{localize(block.caption, lang)}</p>}
            </div>
          ) : block.type === "embed" ? (
            <div class="work-text-block" set:html={renderExternalEmbed({ ...block, caption: localize(block.caption, lang) })} />
          ) : block.type === "statsLink" ? (
            <aside class:list={["work-stats-link", block.previewImage && "work-stats-link-with-thumb"]} aria-label={localize(block.title, lang)}>
              {block.previewImage && (
                <a class="work-stats-link-thumb" href={block.url} target="_blank" rel="noreferrer" aria-label={`Open ${localize(block.title, lang)}`}>
                  <img src={block.previewImage} alt={`${localize(block.title, lang)} thumbnail`} loading="lazy" referrerpolicy="no-referrer" />
                </a>
              )}
              <div class="work-stats-link-content">
                <div class="work-stats-link-main">
                  <div>
                    <h2>{localize(block.title, lang)}</h2>
                    {localize(block.subtitle, lang) && <p class="work-stats-link-subtitle">{localize(block.subtitle, lang)}</p>}
                  </div>
                  <a class="work-stats-link-action" href={block.url} target="_blank" rel="noreferrer">
                    {localize(block.ctaLabel, lang) || "View link"}
                  </a>
                </div>
                {block.stats.length > 0 && (
                  <dl class="work-stats-list">
                    {block.stats.map((stat) => (
                      <div>
                        <dt>{stat.label}</dt>
                        <dd>{stat.value}</dd>
                      </div>
                    ))}
                  </dl>
                )}
              </div>
            </aside>
          ) : null
        ))}
      </div>
    </section>

    {tags.length > 0 && (
      <section class="work-section work-section-full work-tags-section">
        <div>
          <ul class="work-tags" aria-label={`${workTitle} tags`}>
            {tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </div>
      </section>
    )}

  </article>
  {hasXEmbed && <script async src="https://platform.x.com/widgets.js" charset="utf-8"></script>}
  {hasRedditEmbed && <script async src="https://embed.reddit.com/widgets.js" charset="utf-8"></script>}
</Layout>
