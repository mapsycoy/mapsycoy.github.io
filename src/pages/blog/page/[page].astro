---
import BlogIndex from "../../../components/BlogIndex.astro";
import Layout from "../../../layouts/Layout.astro";
import { getBlogPageCount, getBlogPagePosts, getBlogPosts, getNewsPosts } from "../../../data/blog";
import { defaultLanguage } from "../../../utils/i18n";

export async function getStaticPaths() {
  const allPosts = await getBlogPosts();
  const newsPosts = getNewsPosts(allPosts);
  const pageCount = Math.max(2, getBlogPageCount(newsPosts));

  return Array.from({ length: Math.max(0, pageCount - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) },
      props: { allPosts, newsPosts, page },
    };
  });
}

const lang = defaultLanguage;
const { allPosts, newsPosts, page } = Astro.props;
const posts = getBlogPagePosts(newsPosts, page);
---

<Layout title={`Blog Page ${page}`} description="Essays, technical notes, and archived writings by mapsycoy." lang={lang}>
  <BlogIndex posts={posts} allPosts={newsPosts} hubPosts={allPosts} hub pageCountOverride={Math.max(2, getBlogPageCount(newsPosts))} lang={lang} currentPage={page} basePath="/blog" />
</Layout>
