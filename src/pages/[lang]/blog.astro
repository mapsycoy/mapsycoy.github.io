---
import BlogIndex from "../../components/BlogIndex.astro";
import Layout from "../../layouts/Layout.astro";
import { getBlogPagePosts, getBlogPosts, getNewsPosts } from "../../data/blog";
import { getLanguageFromParams, languages, type Language } from "../../utils/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang: Language = getLanguageFromParams(Astro.params.lang);
const allPosts = await getBlogPosts();
const newsPosts = getNewsPosts(allPosts);
const posts = getBlogPagePosts(newsPosts, 1);
---

<Layout title="Blog" description="Essays, technical notes, and archived writings by mapsycoy." lang={lang}>
  <BlogIndex posts={posts} allPosts={newsPosts} hubPosts={allPosts} hub pageCountOverride={Math.max(2, Math.ceil(newsPosts.length / 8))} lang={lang} currentPage={1} basePath={`/${lang}/blog`} />
</Layout>
