---
import BlogIndex from "../../../../components/BlogIndex.astro";
import Layout from "../../../../layouts/Layout.astro";
import { getBlogPageCount, getBlogPagePosts, getBlogPosts } from "../../../../data/blog";
import { languages, type Language } from "../../../../utils/i18n";

export async function getStaticPaths() {
  const allPosts = await getBlogPosts();
  const pageCount = getBlogPageCount(allPosts);

  return languages.flatMap((lang) =>
    Array.from({ length: Math.max(0, pageCount - 1) }, (_, index) => {
      const page = index + 2;
      return {
        params: { lang, page: String(page) },
        props: { allPosts, lang, page },
      };
    })
  );
}

const { allPosts, lang, page } = Astro.props as { allPosts: Awaited<ReturnType<typeof getBlogPosts>>; lang: Language; page: number };
const posts = getBlogPagePosts(allPosts, page);
---

<Layout title={`Blog Page ${page}`} description="Essays, technical notes, and archived writings by mapsycoy." lang={lang}>
  <BlogIndex posts={posts} allPosts={allPosts} lang={lang} currentPage={page} basePath={`/${lang}/blog`} />
</Layout>