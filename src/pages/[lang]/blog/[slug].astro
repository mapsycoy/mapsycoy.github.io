---
import Layout from "../../../layouts/Layout.astro";
import BlogSeriesNav from "../../../components/BlogSeriesNav.astro";
import { render } from "astro:content";
import { getBlogPostSlug, getBlogPosts, getPostDateLabel, getSeriesPosition, hasKoreanText, type BlogPost } from "../../../data/blog";
import { getLanguageFromParams, languages, localize, type Language } from "../../../utils/i18n";
import { smartenText } from "../../../utils/smartTypography.mjs";

export async function getStaticPaths() {
  const posts = await getBlogPosts();

  return languages.flatMap((lang) =>
    posts.map((post) => ({
      params: { lang, slug: getBlogPostSlug(post) },
      props: { post, allPosts: posts, lang: getLanguageFromParams(lang) }
    }))
  );
}

type Props = {
  post: BlogPost;
  allPosts: BlogPost[];
  lang?: Language;
};

const { post, allPosts, lang } = Astro.props;
const seriesPosition = getSeriesPosition(allPosts, post);
const postTitle = localize(post.data.title, lang);
const { Content } = await render(post);
const heroImageCaption = localize(post.data.heroImageCaption, lang).trim();
const contentBlocks = post.data.contentBlocks ?? [];
const footnoteDefinitions = new Map<string, string>();
const footnoteOrder: string[] = [];

contentBlocks
  .filter((block) => block.type === "text")
  .map((block) => localize(block.body, lang))
  .forEach((body) => {
    body
      .trim()
      .split(/\n{2,}/)
      .forEach((block) => {
        const definition = block.trim().match(/^\[\^([^\]]+)\]:\s*([\s\S]*)$/);
        if (definition) footnoteDefinitions.set(definition[1], definition[2].trim());
      });
  });

const getFootnoteSlug = (id: string) =>
  id
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9_-]+/g, "-")
    .replace(/^-+|-+$/g, "") || "note";

const toSuperscriptNumber = (value: number) =>
  String(value).replace(/[0-9]/g, (digit) => ["\u2070", "\u00b9", "\u00b2", "\u00b3", "\u2074", "\u2075", "\u2076", "\u2077", "\u2078", "\u2079"][Number(digit)]);
const renderFootnoteReference = (match: string, id: string) => {
  if (!footnoteDefinitions.has(id)) return match;

  let index = footnoteOrder.indexOf(id);
  if (index === -1) {
    footnoteOrder.push(id);
    index = footnoteOrder.length - 1;
  }

  const number = index + 1;
  const slug = getFootnoteSlug(id);
  const content = footnoteDefinitions.get(id) ?? "";
  return `<sup id="fnref-${slug}" class="footnote-ref-wrap"><button type="button" class="footnote-ref" aria-label="Footnote ${number}">${toSuperscriptNumber(number)}</button><span class="footnote-popover" role="note">${renderInlineMarkdown(content)}</span></sup>`;
};
const escapeHtml = (value: string) =>
  smartenText(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");

const escapeAttribute = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
const renderInlineMarkdown = (value: string) =>
  escapeHtml(value)
    .replace(/\[\^([^\]]+)\]/g, renderFootnoteReference)
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>")
    .replace(/\[((?:[^\[\]]|\[[^\]]*\])+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noreferrer">$1</a>')
    .replace(/&lt;mark&gt;([\s\S]+?)&lt;\/mark&gt;/g, "<mark>$1</mark>");

const splitTableLine = (line: string) =>
  line
    .trim()
    .replace(/^\|/, "")
    .replace(/\|$/, "")
    .split("|")
    .map((cell) => cell.trim());

const isTableSeparator = (line: string) =>
  splitTableLine(line).every((cell) => /^:?-{3,}:?$/.test(cell));

const renderMarkdownTable = (lines: string[]) => {
  const headers = splitTableLine(lines[0]).filter(Boolean);
  const rows = lines.slice(2).map(splitTableLine).filter((cells) => cells.some(Boolean));

  if (!headers.length) return "";

  return [
    "<table>",
    `<thead><tr>${headers.map((cell) => `<th>${renderInlineMarkdown(cell)}</th>`).join("")}</tr></thead>`,
    `<tbody>${rows
      .map((cells) => `<tr>${headers.map((_, index) => `<td>${renderInlineMarkdown(cells[index] ?? "")}</td>`).join("")}</tr>`)
      .join("")}</tbody>`,
    "</table>",
  ].join("");
};

const getListItems = (block: string) => {
  const lines = block.trim().split("\n").map((line) => line.trim()).filter(Boolean);
  const items = lines.map((line) => {
    const unordered = line.match(/^[-*+]\s+(.+)$/);
    const ordered = line.match(/^(\d+)\.\s+(.+)$/);

    if (!unordered && !ordered) return null;

    return {
      type: unordered ? "ul" : "ol",
      start: ordered ? Number(ordered[1]) : undefined,
      content: unordered?.[1] ?? ordered?.[2] ?? "",
    };
  });

  if (items.length > 0 && items.every(Boolean)) {
    return items as NonNullable<(typeof items)[number]>[];
  }

  const firstLine = lines[0] ?? "";
  const unordered = firstLine.match(/^[-*+]\s+(.+)$/);
  const ordered = firstLine.match(/^(\d+)\.\s+(.+)$/);

  if (!unordered && !ordered) return [];

  return [{
    type: unordered ? "ul" : "ol",
    start: ordered ? Number(ordered[1]) : undefined,
    content: [unordered?.[1] ?? ordered?.[2] ?? "", ...lines.slice(1)].join("\n").trim(),
  }];
};

const renderMarkdownList = (items: ReturnType<typeof getListItems>) => {
  const type = items[0]?.type ?? "ul";
  const start = type === "ol" && items[0]?.start && items[0].start !== 1 ? ` start="${items[0].start}"` : "";

  return `<${type}${start}>${items
    .map((item) => `<li>${renderInlineMarkdown(item.content).replace(/\n/g, "<br>")}</li>`)
    .join("")}</${type}>`;
};

const getMermaidSource = (value: string) => {
  const trimmed = value.trim();
  const match = trimmed.match(/^(?:`{4}\s*)?`{3}mermaid\s*([\s\S]*?)`{3}(?:\s*`{4})?$/i);
  if (!match) return "";

  return match[1]
    .replace(/^%%\{init:[\s\S]*?\}%%\s*/i, "")
    .trim();
};

const renderMarkdownBlock = (value: string) => {
  const mermaidSource = getMermaidSource(value);
  if (mermaidSource) return `<pre class="mermaid">${escapeHtml(mermaidSource)}</pre>`;
  const blocks = value.trim().split(/\n{2,}/);
  const html: string[] = [];
  let listItems: ReturnType<typeof getListItems> = [];

  const flushList = () => {
    if (!listItems.length) return;
    html.push(renderMarkdownList(listItems));
    listItems = [];
  };

  blocks.forEach((block) => {
    const trimmed = block.trim();
    const lines = trimmed.split("\n").map((line) => line.trim());
    if (!trimmed || /^\[\^([^\]]+)\]:\s*[\s\S]*$/.test(trimmed)) return;

    const blockListItems = getListItems(trimmed);
    if (blockListItems.length) {
      if (listItems.length && listItems[0].type !== blockListItems[0].type) flushList();
      listItems.push(...blockListItems);
      return;
    }

    flushList();

    if (lines.length >= 2 && lines[0].includes("|") && isTableSeparator(lines[1])) {
      html.push(renderMarkdownTable(lines));
      return;
    }

    if (/^ {0,3}([-*_])(?:\s*\1){2,}\s*$/.test(trimmed)) {
      html.push("<hr>");
      return;
    }

    const heading = trimmed.match(/^(#{1,6})\s+(.+)$/);
    if (heading) {
      html.push(`<h${heading[1].length}>${renderInlineMarkdown(heading[2].trim())}</h${heading[1].length}>`);
      return;
    }

    if (trimmed.split("\n").every((line) => /^>\s?/.test(line.trim()))) {
      const quote = trimmed
        .split("\n")
        .map((line) => line.trim().replace(/^>\s?/, ""))
        .join("\n");

      html.push(`<blockquote>${renderMarkdownBlock(quote)}</blockquote>`);
      return;
    }

    html.push(`<p>${renderInlineMarkdown(trimmed).replace(/\n/g, "<br>")}</p>`);
  });

  flushList();

  return html.join("");
};

const renderFootnotes = () => {
  if (!footnoteOrder.length) return "";

  return `<section class="footnotes" aria-label="Footnotes"><ol>${footnoteOrder
    .map((id, index) => {
      const slug = getFootnoteSlug(id);
      const content = footnoteDefinitions.get(id) ?? "";
      return `<li id="fn-${slug}"><span class="footnote-label">${toSuperscriptNumber(index + 1)}</span> ${renderInlineMarkdown(content)}</li>`;
    })
    .join("")}</ol></section>`;
};
const renderBlogBlock = (block: BlogPost["data"]["contentBlocks"][number]) => {
  if (block.type === "text") return renderMarkdownBlock(localize(block.body, lang));
  if (block.type === "image") {
    const caption = localize(block.caption, lang);
    return `<figure><img src="${escapeAttribute(block.src)}" alt="" loading="lazy">${caption ? `<figcaption>${renderInlineMarkdown(caption)}</figcaption>` : ""}</figure>`;
  }
  if (block.type === "link") {
    const title = localize(block.title, lang);
    const subtitle = localize(block.subtitle, lang);
    return `<p><a href="${escapeAttribute(block.url)}" target="_blank" rel="noreferrer">${renderInlineMarkdown(title || block.url)}</a>${subtitle ? `<br><span>${renderInlineMarkdown(subtitle)}</span>` : ""}</p>`;
  }
  if (block.type === "divider") return "<hr>";
  return "";
};
---

<Layout title={`${postTitle} | Blog`} description={postTitle} lang={lang}>
  <article class="blog-post">
    <a class="work-back-link" href={`/${lang}/blog/`}>&#8592; Blog</a>

    <header class="blog-post-header">
      <p class="entry-meta blog-entry-meta">
        {post.data.pinned && (
          <span class="pin-icon" aria-label="Pinned post">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.7 3.3 20.7 9.3 18.6 11.4 17.2 10 13 14.2V18L11.7 19.3 8.8 16.4 4.4 20.8 3.2 19.6 7.6 15.2 4.7 12.3 6 11H9.8L14 6.8 12.6 5.4 14.7 3.3Z" />
            </svg>
          </span>
        )}
        <span>{post.data.tag}</span>
      </p>
      <h1 class:list={["blog-post-title", hasKoreanText(postTitle) && "ko-title"]}>{postTitle}</h1>
      {seriesPosition && post.data.series === "child-ai" && <BlogSeriesNav posts={seriesPosition.posts} index={seriesPosition.index} seriesId="child-ai" lang={lang} placement="header" />}

      <div class="blog-post-byline" aria-label="Post information">
        <span>{getPostDateLabel(post.data.publishedAt, post.data.updatedAt)}</span>
      </div>
    </header>

    <figure class="blog-post-hero">
      {post.data.heroImage ? (
        <>
          <img src={post.data.heroImage} alt="" loading="eager" />
          {heroImageCaption && (
            <figcaption class:list={[hasKoreanText(heroImageCaption) && "ko-title"]}>
              {heroImageCaption}
            </figcaption>
          )}
        </>
      ) : (
        <div class="blog-post-hero-placeholder" aria-hidden="true"></div>
      )}
    </figure>

    <div class="blog-post-body">
      {contentBlocks.length > 0 ? (
        <>
          {contentBlocks.map((block) => <Fragment set:html={renderBlogBlock(block)} />)}
          <Fragment set:html={renderFootnotes()} />
        </>
      ) : (
        <Content />
      )}
    </div>
    {seriesPosition && post.data.series === "child-ai" && <BlogSeriesNav posts={seriesPosition.posts} index={seriesPosition.index} seriesId="child-ai" lang={lang} placement="footer" />}
  </article>
</Layout>
