---
import { formatPostDate, getBlogPostSlug, getBlogPosts, getNewsPosts, sortBlogPosts } from "../data/blog";
import { defaultLanguage, localize, type Language } from "../utils/i18n";

type Props = { lang?: Language };

const { lang = defaultLanguage } = Astro.props;
const posts = await getBlogPosts();
const recentPosts = [
  ...sortBlogPosts(posts.filter((post) => post.data.tag !== "AI News")).slice(0, 2),
  ...getNewsPosts(posts).slice(0, 1),
];
const languagePrefix = lang === defaultLanguage ? "" : `/${lang}`;
---

{recentPosts.length > 0 && (
  <section class="home-recent" aria-labelledby="home-recent-title">
    <div id="home-recent-title" class="home-kicker">Recent</div>
    <ul>
      {recentPosts.map((post) => (
        <li>
          <a href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`}>
            <time datetime={post.data.publishedAt.toISOString()}>{formatPostDate(post.data.publishedAt)}</time>
            <span aria-hidden="true"> — </span>
            <span class="home-recent-title">{localize(post.data.title, lang)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style is:inline>
  .home-recent {
    min-width: 0;
    overflow: hidden;
  }

  .home-recent ul,
  .home-recent li {
    min-width: 0;
  }

  .home-recent a {
    display: flex;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    align-items: baseline;
  }

  .home-recent a > time,
  .home-recent a > span:not(.home-recent-title) {
    flex: 0 0 auto;
  }

  .home-recent-title {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
