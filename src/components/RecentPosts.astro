---
import { getBlogPostSlug, getBlogPosts, getNewsPosts, sortBlogPosts } from "../data/blog";
import { defaultLanguage, localize, type Language } from "../utils/i18n";

type Props = { lang?: Language };

const { lang = defaultLanguage } = Astro.props;
const posts = await getBlogPosts();
const recentPosts = [
  ...sortBlogPosts(posts.filter((post) => post.data.tag === "Essay")).slice(0, 1),
  ...sortBlogPosts(posts.filter((post) => post.data.tag === "Paper")).slice(0, 1),
  ...getNewsPosts(posts).slice(0, 1),
];
const languagePrefix = lang === defaultLanguage ? "" : `/${lang}`;
---

{recentPosts.length > 0 && (
  <section class="home-recent" aria-labelledby="home-recent-title">
    <div id="home-recent-title" class="home-kicker">Latest Posts</div>
    <ul>
      {recentPosts.map((post) => (
        <li>
          <a href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`}>
            <span class="home-recent-track">{post.data.tag}</span>
            <span class="home-recent-title">{localize(post.data.title, lang)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style is:inline>
  .home-recent {
    min-width: 0;
    overflow: hidden;
  }

  .home-recent ul,
  .home-recent li {
    min-width: 0;
  }

  .home-recent a {
    display: flex;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    align-items: center;
    gap: 10px;
  }

  .home-recent a > span:not(.home-recent-title) {
    flex: 0 0 auto;
  }

  .home-recent-track {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px 4px;
    background: var(--soft);
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .home-recent-title {
    min-width: 0;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
