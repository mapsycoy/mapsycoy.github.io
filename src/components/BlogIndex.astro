---
import {
  blogTags,
  getNonSeriesPosts,
  getBlogPostSlug,
  getBlogPageCount,
  getSeriesPosts,
  formatPostDate,
  getPostDateLabel,
  hasKoreanText,
  normalizeBlogTag,
  type BlogPost,
  type BlogTag,
} from "../data/blog";
import { series } from "../data/series";
import { defaultLanguage, localize, type Language } from "../utils/i18n";

type Props = {
  posts: BlogPost[];
  allPosts: BlogPost[];
  lang?: Language;
  currentPage?: number;
  basePath?: string;
  activeTag?: BlogTag;
  hub?: boolean;
  hubPosts?: BlogPost[];
  pageCountOverride?: number;
};

const {
  posts,
  allPosts,
  lang = defaultLanguage,
  currentPage = 1,
  basePath = "/blog",
  activeTag,
  hub = false,
  hubPosts = allPosts,
  pageCountOverride,
} = Astro.props;

const normalizedBasePath = `/${basePath.replace(/^\/+|\/+$/g, "")}`;
const pageCount = pageCountOverride ?? getBlogPageCount(allPosts);
const toPagePath = (page: number) => {
  if (page <= 1) return `${normalizedBasePath}/`;
  return `${normalizedBasePath}/page/${page}/`;
};
const languagePrefix = lang === defaultLanguage ? "" : `/${lang}`;
const allPath = `${languagePrefix}/blog/`;
const tagPath = (tag: BlogTag) => `${languagePrefix}/blog/tag/${normalizeBlogTag(tag)}/`;
const seriesPosts = hub ? getSeriesPosts(hubPosts, "child-ai") : [];
const nonSeriesPosts = hub ? getNonSeriesPosts(hubPosts) : [];
const seriesMeta = series["child-ai"];
const paginationItems = (() => {
  const pages = new Set([1, pageCount, currentPage - 1, currentPage, currentPage + 1]);
  const sortedPages = [...pages]
    .filter((page) => page >= 1 && page <= pageCount)
    .sort((a, b) => a - b);
  const items: Array<number | "ellipsis"> = [];

  sortedPages.forEach((page) => {
    const previous = items[items.length - 1];
    if (typeof previous === "number" && page - previous > 1) items.push("ellipsis");
    items.push(page);
  });

  return items;
})();
---

<section class="works-filter" aria-label="Filter blog entries by tag">
  <a class:list={["work-filter-button", !activeTag && "is-active"]} href={allPath} aria-current={!activeTag ? "page" : undefined}>
    All
  </a>
  {blogTags.map((tag) => (
    <a
      class:list={["work-filter-button", activeTag === tag && "is-active"]}
      href={tagPath(tag)}
      aria-current={activeTag === tag ? "page" : undefined}
    >
      {tag}
    </a>
  ))}
</section>

{hub && currentPage === 1 ? (
  <div class="blog-hub">
    <section id="series-child-ai" class="blog-text-section" aria-labelledby="series-child-ai-title">
      <h1 id="series-child-ai-title">{localize(seriesMeta.title, lang)}</h1>
      <p class="blog-series-description">{localize(seriesMeta.description, lang)}</p>
      <ol class="blog-text-list">
        {seriesPosts.map((post) => (
          <li value={post.data.seriesOrder}>
            <a href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`}>
              <span class:list={[hasKoreanText(localize(post.data.title, lang)) && "ko-title"]}>{localize(post.data.title, lang)}</span>
              {post.data.summary && localize(post.data.summary, lang).trim() && (
                <span class="blog-list-summary"> — {localize(post.data.summary, lang)}</span>
              )}
              <time datetime={post.data.publishedAt.toISOString()}>{formatPostDate(post.data.publishedAt)}</time>
            </a>
          </li>
        ))}
      </ol>
    </section>

    {nonSeriesPosts.length > 0 && (
      <section class="blog-text-section" aria-labelledby="other-posts-title">
        <h2 id="other-posts-title">{lang === "ko" ? "시리즈 외 글" : "Other writing"}</h2>
        <ul class="blog-text-list">
          {nonSeriesPosts.map((post) => (
            <li><a href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`}><span>{localize(post.data.title, lang)}</span><time datetime={post.data.publishedAt.toISOString()}>{formatPostDate(post.data.publishedAt)}</time></a></li>
          ))}
        </ul>
      </section>
    )}

    <section class="blog-text-section" aria-labelledby="news-archive-title">
      <h2 id="news-archive-title">News / Archive</h2>
      <ul class="blog-text-list">
        {posts.map((post) => (
          <li><a href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`}><span>{localize(post.data.title, lang)}</span><time datetime={post.data.publishedAt.toISOString()}>{formatPostDate(post.data.publishedAt)}</time></a></li>
        ))}
      </ul>
    </section>
  </div>
) : hub ? (
  <div class="blog-hub">
    <a class="blog-series-return" href={`${languagePrefix}/blog/#series-child-ai`}>&larr; {lang === "ko" ? "시리즈 목록으로" : "Back to the series"}</a>
    <section class="blog-text-section" aria-labelledby="news-archive-title">
      <h1 id="news-archive-title">News / Archive</h1>
      <ul class="blog-text-list">
        {posts.map((post) => (
          <li><a href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`}><span>{localize(post.data.title, lang)}</span><time datetime={post.data.publishedAt.toISOString()}>{formatPostDate(post.data.publishedAt)}</time></a></li>
        ))}
      </ul>
    </section>
  </div>
) : (
<section class="entry-list blog-entry-list" aria-label="Blog entries">
  {posts.map((post, index) => (
    <article
      class:list={[
        "blog-entry",
        index === 0 && "is-first-visible",
        index === posts.length - 1 && "is-last-visible"
      ]}
    >
      <a class="blog-entry-link" href={`${languagePrefix}/blog/${getBlogPostSlug(post)}/`} aria-label={`Open ${localize(post.data.title, lang)} post`}>
        <div class="blog-entry-copy">
          <p class="entry-meta blog-entry-meta">
            {post.data.pinned && (
              <span class="pin-icon" aria-label="Pinned post">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M14.7 3.3 20.7 9.3 18.6 11.4 17.2 10 13 14.2V18L11.7 19.3 8.8 16.4 4.4 20.8 3.2 19.6 7.6 15.2 4.7 12.3 6 11H9.8L14 6.8 12.6 5.4 14.7 3.3Z" />
                </svg>
              </span>
            )}
            <span>{post.data.tag}</span>
          </p>
          <h2 class:list={[hasKoreanText(localize(post.data.title, lang)) && "ko-title"]}>{localize(post.data.title, lang)}</h2>
          <p class="blog-entry-date">
            {getPostDateLabel(post.data.publishedAt, post.data.updatedAt)}
          </p>
        </div>
        <div class="blog-entry-thumb" aria-label={`${localize(post.data.title, lang)} thumbnail`}>
          {post.data.thumbnail ? (
            <img src={post.data.thumbnail} alt="" loading="lazy" />
          ) : (
            <div class="blog-entry-thumb-placeholder" aria-hidden="true"></div>
          )}
        </div>
      </a>
    </article>
  ))}
</section>
)}

{pageCount > 1 && (
  <nav class="blog-pagination" aria-label="Blog pagination">
    <div class="blog-pagination-side blog-pagination-previous">
      {currentPage > 1 && (
        <a class="blog-page-button blog-page-arrow" href={toPagePath(currentPage - 1)} aria-label="Previous page">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="m14.5 5-7 7 7 7" />
          </svg>
        </a>
      )}
    </div>
    <div class="blog-page-numbers">
      {paginationItems.map((item) => {
        if (item === "ellipsis") {
          return <span class="blog-page-ellipsis" aria-hidden="true">...</span>;
        }

        return (
          <a
            class:list={["blog-page-button", item === currentPage && "is-active"]}
            href={toPagePath(item)}
            aria-current={item === currentPage ? "page" : undefined}
          >
            {item}
          </a>
        );
      })}
    </div>
    <div class="blog-pagination-side blog-pagination-next">
      {currentPage < pageCount && (
        <a class="blog-page-button blog-page-arrow" href={toPagePath(currentPage + 1)} aria-label="Next page">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="m9.5 5 7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  </nav>
)}
