        stroke-linejoin: miter;
        fill: none;
      }
      #dot-to-o { fill: #0a0a0a; stroke: none; }

      @media (prefers-reduced-motion: reduce) {
        #initial-rounded-hangul,
        #marks,
        #dot-to-o {
          opacity: 0 !important;
