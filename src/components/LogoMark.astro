<script>
  const INTRO_END = 3.6;
  const HANGUL_TIME = 0;
  const LATIN_TIME = INTRO_END;
  const DECOMPOSED_HOLD = INTRO_END * 0.38;
  const REVERSE_DURATION = 950;
  const RESTORE_DURATION = 760;
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  const initializeLogoMarks = () => {
    document.querySelectorAll("[data-logo-mark]").forEach((logo) => {
      if (!(logo instanceof HTMLElement) || logo.dataset.logoMarkInitialized === "true") return;

      const svg = logo.querySelector("svg");
      if (!(svg instanceof SVGSVGElement)) return;

      logo.dataset.logoMarkInitialized = "true";

      let frame = 0;
      let currentRestState = "latin";

      const stopScrub = () => {
        if (frame) {
          cancelAnimationFrame(frame);
          frame = 0;
        }
      };

      const setTimeline = (time) => {
        svg.setCurrentTime(Math.max(HANGUL_TIME, Math.min(LATIN_TIME, time)));
      };

      const scrubTo = (target, duration, onComplete) => {
        stopScrub();
        svg.pauseAnimations();

        const start = svg.getCurrentTime();
        const change = target - start;
        const startedAt = performance.now();

        const step = (now) => {
          const progress = Math.min((now - startedAt) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          setTimeline(start + change * eased);

          if (progress < 1) {
            frame = requestAnimationFrame(step);
            return;
          }

          frame = 0;
          onComplete?.();
        };

        frame = requestAnimationFrame(step);
      };

      const showCompleted = () => {
        stopScrub();
        svg.pauseAnimations();
        svg.setCurrentTime(INTRO_END);
      };

      if (reducedMotion.matches) {
        showCompleted();
        return;
      }

      logo.addEventListener("pointerenter", () => {
        if (reducedMotion.matches) {
          showCompleted();
          return;
        }

        scrubTo(DECOMPOSED_HOLD, REVERSE_DURATION);
      });

      logo.addEventListener("pointerleave", () => {
        if (reducedMotion.matches) {
          showCompleted();
          return;
        }

        const nextRestState = currentRestState === "latin" ? "hangul" : "latin";
        const nextTime = nextRestState === "hangul" ? HANGUL_TIME : LATIN_TIME;

        scrubTo(nextTime, RESTORE_DURATION, () => {
          currentRestState = nextRestState;
        });
      });

      if ("addEventListener" in reducedMotion) {
        reducedMotion.addEventListener("change", (event) => {
          if (event.matches) showCompleted();
        });
      } else {
        reducedMotion.addListener((event) => {
          if (event.matches) showCompleted();
        });
      }
    });
  };

  initializeLogoMarks();
  document.addEventListener("astro:page-load", initializeLogoMarks);
</script>
