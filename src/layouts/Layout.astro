---
import "../styles/global.css";
import ClientRouter from "astro/components/ClientRouter.astro";
import LogoMark from "../components/LogoMark.astro";
import { getSitePreviewImage } from "../data/home";
import { defaultLanguage, getAlternateLanguage, isLanguage, withLanguage, type Language } from "../utils/i18n";

const {
  title = "mapsycoy",
  description = "Visual Creation, AI Workflows, and Human-Centered Interaction.",
  previewImage = getSitePreviewImage(),
  lang = defaultLanguage
} = Astro.props;

const currentLanguage = lang as Language;
const siteUrl = "https://mapsycoy.github.io";
const pageTitle = title === "mapsycoy" ? "mapsycoy" : `${title} | mapsycoy`;
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const previewImageUrl = new URL(previewImage, siteUrl).toString();

const navItems = [
  { href: withLanguage(currentLanguage, "/works"), label: "Works" },
  { href: withLanguage(currentLanguage, "/blog"), label: "Blog" },
  { href: withLanguage(currentLanguage, "/cv"), label: "CV" }
];
const pathParts = Astro.url.pathname.split("/").filter(Boolean);
const hasLanguagePrefix = isLanguage(pathParts[0]);
const alternateLanguage = getAlternateLanguage(currentLanguage);
const alternatePath = hasLanguagePrefix
  ? `/${[alternateLanguage, ...pathParts.slice(1)].join("/")}`
  : withLanguage(alternateLanguage, Astro.url.pathname);

const linkedInUrl = "https://www.linkedin.com/in/mapsycoy/";
const instagramUrl = "https://www.instagram.com/mapsycoy/";
---

<!doctype html>
<html lang={currentLanguage}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={previewImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImageUrl} />
    <title>{pageTitle}</title>
    <ClientRouter fallback="swap" />
    <style is:inline>
      html { overflow-y: scroll; }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label="Site header">
        <a class="site-title" href={withLanguage(currentLanguage, "/")} aria-label="mapsycoy home">
          <LogoMark />
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a class="language-toggle" href={alternatePath} aria-label={`Switch to ${alternateLanguage.toUpperCase()}`}>
            {alternateLanguage.toUpperCase()}
          </a>
        </nav>
      </header>

      <main>
        <slot />
      </main>
      <div class="site-music-float" data-site-music-float hidden>
        <button
          class="site-music-float-toggle"
          type="button"
          aria-pressed="false"
          aria-label="Play music"
          data-site-music-control
        >
          <span class="site-music-float-icon" aria-hidden="true">
            <svg class="site-music-float-play" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5.5v13l11-6.5-11-6.5Z" />
            </svg>
            <svg class="site-music-float-pause" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 5.5h3.5v13H7v-13Zm6.5 0H17v13h-3.5v-13Z" />
            </svg>
          </span>
          <span class="sr-only" data-site-music-label>Music</span>
        </button>
        <button
          class="site-music-float-dismiss"
          type="button"
          aria-label="Hide music control"
          data-site-music-dismiss
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6.7 5.65 5.3 5.3 5.3-5.3 1.05 1.05-5.3 5.3 5.3 5.3-1.05 1.05-5.3-5.3-5.3 5.3-1.05-1.05 5.3-5.3-5.3-5.3 1.05-1.05Z" />
          </svg>
        </button>
      </div>
      <footer class="site-footer">
        <p>&copy; Kim Junyeop. All rights reserved.</p>
        <div class="footer-social-links">
          <a
            class="footer-social-link"
            href={linkedInUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Kim Junyeop on LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5.35 8.85h3.12v9.78H5.35V8.85Zm1.56-4.86c1 0 1.81.81 1.81 1.81s-.81 1.81-1.81 1.81S5.1 6.8 5.1 5.8s.81-1.81 1.81-1.81Zm3.47 4.86h2.99v1.34h.04c.42-.79 1.43-1.62 2.95-1.62 3.15 0 3.73 2.07 3.73 4.76v5.3h-3.12v-4.7c0-1.12-.02-2.56-1.56-2.56-1.56 0-1.8 1.22-1.8 2.48v4.78h-3.23V8.85Z" />
            </svg>
          </a>
          <a
            class="footer-social-link"
            href={instagramUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="mapsycoy on Instagram"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7.75 2.9h8.5a4.85 4.85 0 0 1 4.85 4.85v8.5a4.85 4.85 0 0 1-4.85 4.85h-8.5a4.85 4.85 0 0 1-4.85-4.85v-8.5A4.85 4.85 0 0 1 7.75 2.9Zm0 1.9A2.95 2.95 0 0 0 4.8 7.75v8.5a2.95 2.95 0 0 0 2.95 2.95h8.5a2.95 2.95 0 0 0 2.95-2.95v-8.5a2.95 2.95 0 0 0-2.95-2.95h-8.5Zm4.25 3a4.2 4.2 0 1 1 0 8.4 4.2 4.2 0 0 1 0-8.4Zm0 1.9a2.3 2.3 0 1 0 0 4.6 2.3 2.3 0 0 0 0-4.6Zm4.45-2.25a1.05 1.05 0 1 1 0 2.1 1.05 1.05 0 0 1 0-2.1Z" />
            </svg>
          </a>
        </div>
      </footer>
    </div>

    <script is:inline>
      const createMusicSystem = () => {
        const storageKey = "mapsycoy:music";
        const floatHiddenKey = "mapsycoy:music-float-hidden";
        const audio = new Audio();
        audio.preload = "metadata";
        let controls = [];
        let floatingControl = null;

        const readState = () => {
          try {
            return JSON.parse(window.localStorage.getItem(storageKey) || "{}");
          } catch {
            return {};
          }
        };

        const writeState = () => {
          const activeControl = controls.find(({ root }) => root.dataset.title);
          try {
            window.localStorage.setItem(storageKey, JSON.stringify({
              src: audio.currentSrc || audio.src,
              currentTime: audio.currentTime || 0,
              wasPlaying: !audio.paused && !audio.ended,
              title: activeControl?.root.dataset.title || readState().title || ""
            }));
          } catch {
            // Storage can be unavailable in private browsing modes.
          }
        };

        const formatTime = (value) => {
          if (!Number.isFinite(value) || value <= 0) return "00:00";

          const minutes = Math.floor(value / 60);
          const seconds = Math.floor(value % 60);
          return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
        };

        const normalizeSrc = (src) => {
          if (!src) return "";
          return new URL(src, window.location.href).href;
        };

        const isFloatingHidden = () => {
          try {
            return window.localStorage.getItem(floatHiddenKey) === "true";
          } catch {
            return false;
          }
        };

        const showFloatingControl = () => {
          try {
            window.localStorage.removeItem(floatHiddenKey);
          } catch {
            // Storage can be unavailable in private browsing modes.
          }
        };

        const updateFloatingPosition = () => {
          if (!floatingControl?.root) return;
          const footer = document.querySelector(".site-footer");
          const baseOffset = 18;
          let bottomOffset = baseOffset;

          if (footer instanceof HTMLElement) {
            const footerRect = footer.getBoundingClientRect();
            if (footerRect.top < window.innerHeight) {
              bottomOffset = Math.max(baseOffset, window.innerHeight - footerRect.top + baseOffset);
            }
          }

          floatingControl.root.style.setProperty("--site-music-float-bottom", `${Math.round(bottomOffset)}px`);
        };

        const updateControls = () => {
          const duration = audio.duration || 0;
          const currentTime = audio.currentTime || 0;
          const isPlaying = !audio.paused && !audio.ended;
          const state = readState();
          const hasMusic = Boolean(audio.currentSrc || audio.src || state.src);
          const isHomePage = Boolean(document.querySelector("[data-home-music]"));

          controls.forEach(({ root, button, progress, time }) => {
            if (progress) progress.value = duration ? String((currentTime / duration) * 100) : "0";
            if (time) time.textContent = `${formatTime(currentTime)} / ${formatTime(duration)}`;
            root.classList.toggle("is-playing", isPlaying);
            button.setAttribute("aria-pressed", String(isPlaying));
            button.setAttribute("aria-label", `${isPlaying ? "Pause" : "Play"} ${root.dataset.title || "music"}`);
          });

          if (floatingControl) {
            const { root, button, label } = floatingControl;
            const title = controls.find(({ root }) => root.dataset.title)?.root.dataset.title || state.title || "music";
            root.hidden = isHomePage || !hasMusic || isFloatingHidden();
            root.classList.toggle("is-playing", isPlaying);
            button.setAttribute("aria-pressed", String(isPlaying));
            button.setAttribute("aria-label", `${isPlaying ? "Pause" : "Play"} ${title}`);
            if (label) label.textContent = title;
            updateFloatingPosition();
          }
        };

        const setSource = (src) => {
          const nextSrc = normalizeSrc(src);
          if (!nextSrc || normalizeSrc(audio.src) === nextSrc) return;
          audio.src = nextSrc;
          audio.load();
        };

        const bind = () => {
          controls = [];
          const floatingRoot = document.querySelector("[data-site-music-float]");
          const floatingButton = document.querySelector("[data-site-music-control]");
          const floatingDismiss = document.querySelector("[data-site-music-dismiss]");
          if (floatingRoot instanceof HTMLElement && floatingButton instanceof HTMLButtonElement) {
            floatingControl = {
              root: floatingRoot,
              button: floatingButton,
              dismiss: floatingDismiss instanceof HTMLButtonElement ? floatingDismiss : null,
              label: floatingButton.querySelector("[data-site-music-label]")
            };

            if (floatingButton.dataset.musicBound !== "true") {
              floatingButton.dataset.musicBound = "true";
              floatingButton.addEventListener("click", async () => {
                const state = readState();
                if (!audio.src && state.src) setSource(state.src);
                if (!audio.src) return;

                if (audio.paused || audio.ended) {
                  showFloatingControl();
                  try {
                    await audio.play();
                  } catch {
                    updateControls();
                  }
                  return;
                }

                audio.pause();
              });
            }

            if (floatingControl.dismiss && floatingControl.dismiss.dataset.musicBound !== "true") {
              floatingControl.dismiss.dataset.musicBound = "true";
              floatingControl.dismiss.addEventListener("click", () => {
                audio.pause();
                try {
                  window.localStorage.setItem(floatHiddenKey, "true");
                } catch {
                  // Storage can be unavailable in private browsing modes.
                }
                updateControls();
              });
            }
          }

          document.querySelectorAll("[data-home-music]").forEach((root) => {
            if (!(root instanceof HTMLElement)) return;

            const button = root.querySelector(".home-music-toggle");
            const progress = root.querySelector(".home-music-progress");
            const time = root.querySelector("[data-home-music-time]");
            const audioFile = root.dataset.audioFile || "";

            if (
              !(button instanceof HTMLButtonElement) ||
              !(progress instanceof HTMLInputElement) ||
              !(time instanceof HTMLElement)
            ) return;

            if (!audioFile) {
              button.disabled = true;
              progress.disabled = true;
              root.classList.add("is-unavailable");
              return;
            }

            root.classList.remove("is-unavailable");
            button.disabled = false;
            progress.disabled = false;

            if (!audio.src) {
              setSource(audioFile);
            }

            controls.push({ root, button, progress, time });

            if (root.dataset.musicBound === "true") return;
            root.dataset.musicBound = "true";

            button.addEventListener("click", async () => {
              setSource(audioFile);
              showFloatingControl();

              if (audio.paused || audio.ended) {
                try {
                  await audio.play();
                } catch {
                  updateControls();
                }
                return;
              }

              audio.pause();
            });

            progress.addEventListener("input", () => {
              const duration = audio.duration || 0;
              if (!duration) return;
              audio.currentTime = (Number(progress.value) / 100) * duration;
              updateControls();
              writeState();
            });
          });

          document.querySelectorAll(".work-video-embed").forEach((videoEmbed) => {
            if (!(videoEmbed instanceof HTMLElement) || videoEmbed.dataset.musicPauseBound === "true") return;
            videoEmbed.dataset.musicPauseBound = "true";
            const pauseMusic = () => {
              if (!audio.paused && !audio.ended) audio.pause();
            };
            videoEmbed.addEventListener("pointerdown", pauseMusic, { passive: true });
            videoEmbed.addEventListener("focusin", pauseMusic);
          });

          updateControls();
        };

        const restore = () => {
          const state = readState();
          if (!state.src) return;

          setSource(state.src);

          audio.addEventListener("loadedmetadata", () => {
            if (Number.isFinite(state.currentTime)) {
              audio.currentTime = Math.min(state.currentTime, audio.duration || state.currentTime);
            }

            if (state.wasPlaying) {
              audio.play().catch(() => updateControls());
            }
          }, { once: true });
        };

        ["loadedmetadata", "timeupdate", "play", "pause", "ended", "durationchange"].forEach((eventName) => {
          audio.addEventListener(eventName, () => {
            updateControls();
            writeState();
          });
        });

        window.addEventListener("pagehide", writeState);
        window.addEventListener("scroll", updateFloatingPosition, { passive: true });
        window.addEventListener("resize", updateFloatingPosition, { passive: true });
        document.addEventListener("astro:page-load", bind);
        document.addEventListener("DOMContentLoaded", bind);

        restore();
        bind();

        return { audio, bind };
      };

      if (!window.__mapsycoyMusicSystem) {
        window.__mapsycoyMusicSystem = createMusicSystem();
      } else {
        window.__mapsycoyMusicSystem.bind();
      }
      const initializeWorksFilters = () => {
        document.querySelectorAll("[data-works-filter]").forEach((filterRoot) => {
          if (!(filterRoot instanceof HTMLElement) || filterRoot.dataset.filterBound === "true") return;
          filterRoot.dataset.filterBound = "true";

          const buttons = Array.from(filterRoot.querySelectorAll("[data-filter]"));
          const toggleButton = filterRoot.querySelector("[data-filter-toggle]");
          const workCards = Array.from(document.querySelectorAll("[data-work-card]"));
          const workSections = Array.from(document.querySelectorAll("[data-work-section]"));

          const applyFilter = (activeButton) => {
            const filter = activeButton.dataset.filter ?? "all";

            buttons.forEach((button) => {
              const isActive = button === activeButton;
              button.classList.toggle("is-active", isActive);
              button.setAttribute("aria-pressed", isActive ? "true" : "false");
            });

            workCards.forEach((card) => {
              if (!(card instanceof HTMLElement)) return;
              const tags = card.dataset.tags ?? "";
              const shouldShow = filter === "all" || tags.split(" ").includes(filter);
              card.hidden = !shouldShow;
            });

            workSections.forEach((section) => {
              if (!(section instanceof HTMLElement)) return;
              const cards = Array.from(section.querySelectorAll("[data-work-card]"));
              const hasVisibleCard = cards.some((card) => card instanceof HTMLElement && !card.hidden);
              section.hidden = !hasVisibleCard;
            });
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => applyFilter(button));
          });

          if (toggleButton instanceof HTMLButtonElement) {
            toggleButton.addEventListener("click", () => {
              const willExpand = !filterRoot.classList.contains("is-expanded");
              filterRoot.classList.toggle("is-expanded", willExpand);
              toggleButton.textContent = willExpand ? "\u00d7" : "\u00b7\u00b7\u00b7";
              toggleButton.setAttribute("aria-expanded", willExpand ? "true" : "false");
              toggleButton.setAttribute("aria-label", willExpand ? "Show fewer categories" : "Show more categories");

              if (!willExpand) {
                const allButton = buttons.find((button) => button.dataset.filter === "all");
                if (allButton instanceof HTMLButtonElement) applyFilter(allButton);
              }
            });
          }
        });
      };

      const initializeBlogFilters = () => {
        document.querySelectorAll("[data-blog-filter]").forEach((filterRoot) => {
          if (!(filterRoot instanceof HTMLElement) || filterRoot.dataset.filterBound === "true") return;
          filterRoot.dataset.filterBound = "true";

          const entries = Array.from(document.querySelectorAll("[data-blog-entry]"));
          const pagination = document.querySelector("[data-blog-pagination]");
          const pageSize = pagination instanceof HTMLElement ? Number(pagination.dataset.pageSize ?? "8") : 8;
          const pageNumbers = pagination?.querySelector("[data-page-numbers]");
          let currentFilter = "all";
          let currentPage = 1;

          const getFilteredEntries = () => entries.filter((entry) => {
            if (!(entry instanceof HTMLElement)) return false;
            const tags = entry.dataset.tags ?? "";
            return currentFilter === "all" || tags.split(" ").includes(currentFilter);
          });

          const renderEntries = () => {
            const filteredEntries = getFilteredEntries();
            const pageCount = Math.max(1, Math.ceil(filteredEntries.length / pageSize));
            currentPage = Math.min(currentPage, pageCount);
            const startIndex = (currentPage - 1) * pageSize;
            const visibleEntries = filteredEntries.slice(startIndex, startIndex + pageSize);

            entries.forEach((entry) => {
              if (!(entry instanceof HTMLElement)) return;
              entry.classList.remove("is-first-visible", "is-last-visible");
              entry.hidden = !visibleEntries.includes(entry);
            });

            visibleEntries[0]?.classList.add("is-first-visible");
            visibleEntries[visibleEntries.length - 1]?.classList.add("is-last-visible");

            if (pagination instanceof HTMLElement) pagination.hidden = false;

            if (pageNumbers instanceof HTMLElement) {
              Array.from(pageNumbers.querySelectorAll("[data-page-number]")).forEach((button) => {
                if (!(button instanceof HTMLButtonElement)) return;
                const page = Number(button.dataset.pageNumber ?? "1");
                const isVisiblePage = page <= pageCount;
                const isActivePage = page === currentPage;
                button.hidden = !isVisiblePage;
                button.classList.toggle("is-active", isActivePage);
                if (isActivePage) {
                  button.setAttribute("aria-current", "page");
                } else {
                  button.removeAttribute("aria-current");
                }
              });
            }
          };

          const buttons = Array.from(filterRoot.querySelectorAll("[data-filter]"));
          buttons.forEach((button) => {
            button.addEventListener("click", () => {
              currentFilter = button.dataset.filter ?? "all";
              currentPage = 1;

              buttons.forEach((item) => {
                const isActive = item === button;
                item.classList.toggle("is-active", isActive);
                item.setAttribute("aria-pressed", isActive ? "true" : "false");
              });

              renderEntries();
            });
          });

          if (pageNumbers instanceof HTMLElement) {
            pageNumbers.addEventListener("click", (event) => {
              const target = event.target;
              if (!(target instanceof HTMLButtonElement)) return;
              currentPage = Number(target.dataset.pageNumber ?? "1");
              renderEntries();
            });
          }

          renderEntries();
        });
      };

      const initializeCvToggles = () => {
        document.querySelectorAll("[data-cv-section]").forEach((section) => {
          if (!(section instanceof HTMLElement)) return;

          const toggle = section.querySelector("[data-cv-toggle]");
          if (!(toggle instanceof HTMLButtonElement) || toggle.dataset.cvToggleBound === "true") return;
          toggle.dataset.cvToggleBound = "true";

          const items = Array.from(section.querySelectorAll("[data-cv-item]"));
          const initialCount = Number(toggle.dataset.initialCount ?? items.length);
          const totalCount = Number(toggle.dataset.totalCount ?? items.length);
          const label = toggle.dataset.label ?? "items";

          const setExpanded = (isExpanded) => {
            items.forEach((item, index) => {
              if (!(item instanceof HTMLElement)) return;
              item.hidden = !isExpanded && index >= initialCount;
            });

            toggle.setAttribute("aria-expanded", isExpanded ? "true" : "false");
            toggle.textContent = isExpanded
              ? "Show fewer"
              : `Show all ${totalCount} ${label}`;
          };

          toggle.addEventListener("click", () => {
            setExpanded(toggle.getAttribute("aria-expanded") !== "true");
          });
        });
      };

      const positionFootnotePopover = (wrap) => {
        const trigger = wrap.querySelector(".footnote-ref");
        const popover = wrap.querySelector(".footnote-popover");
        if (!(trigger instanceof HTMLElement) || !(popover instanceof HTMLElement)) return;

        popover.classList.remove("is-positioned");
        if (!window.matchMedia("(max-width: 680px)").matches) return;

        requestAnimationFrame(() => {
          const margin = 20;
          const gap = 8;
          const triggerRect = trigger.getBoundingClientRect();
          const popoverRect = popover.getBoundingClientRect();
          const left = Math.min(
            window.innerWidth - margin - popoverRect.width,
            Math.max(margin, triggerRect.left + (triggerRect.width / 2) - (popoverRect.width / 2))
          );
          const top = Math.max(margin, triggerRect.top - popoverRect.height - gap);

          popover.style.setProperty("--footnote-popover-left", `${Math.round(left)}px`);
          popover.style.setProperty("--footnote-popover-top", `${Math.round(top)}px`);
          popover.classList.add("is-positioned");
        });
      };

      const initializeFootnotePopovers = () => {
        document.querySelectorAll(".footnote-ref-wrap").forEach((wrap) => {
          if (!(wrap instanceof HTMLElement) || wrap.dataset.footnoteBound === "true") return;
          wrap.dataset.footnoteBound = "true";

          const update = () => positionFootnotePopover(wrap);
          const clear = () => {
            const popover = wrap.querySelector(".footnote-popover");
            if (popover instanceof HTMLElement) popover.classList.remove("is-positioned");
          };

          wrap.addEventListener("pointerenter", update);
          wrap.addEventListener("focusin", update);
          wrap.addEventListener("click", update);
          wrap.addEventListener("pointerleave", clear);
          wrap.addEventListener("focusout", clear);
        });
      };

      window.addEventListener("resize", () => {
        document.querySelectorAll(".footnote-ref-wrap:focus-within, .footnote-ref-wrap:hover").forEach((wrap) => {
          if (wrap instanceof HTMLElement) positionFootnotePopover(wrap);
        });
      }, { passive: true });
      const initializePageInteractions = () => {
        initializeWorksFilters();
        initializeBlogFilters();
        initializeCvToggles();
        initializeFootnotePopovers();
      };

      document.addEventListener("astro:page-load", initializePageInteractions);
      document.addEventListener("DOMContentLoaded", initializePageInteractions);
      initializePageInteractions();
      const protectImages = () => {
        document.querySelectorAll("img").forEach((image) => {
          image.setAttribute("draggable", "false");
        });
      };

      document.addEventListener("contextmenu", (event) => {
        if (event.target instanceof HTMLImageElement) {
          event.preventDefault();
        }
      });

      document.addEventListener("dragstart", (event) => {
        if (event.target instanceof HTMLImageElement) {
          event.preventDefault();
        }
      });

      document.addEventListener("DOMContentLoaded", protectImages);
      protectImages();
    </script>
  </body>
</html>
